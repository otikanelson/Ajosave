{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@VITE_API_URL",
    "VITE_ADMIN_SUBDOMAIN": "@VITE_ADMIN_SUBDOMAIN"
  },
  "routes": [
    {
      "src": "^/admin/.*",
      "dest": "/index.html"
    },
    {
      "src": "^/.*",
      "dest": "/index.html"   
    }
  ]
}
