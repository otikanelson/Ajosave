{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_ADMIN_SUBDOMAIN": "@vite_admin_subdomain"
  },
  "routes": [
    {
      "src": "^/admin/.*",
      "dest": "/index.html"
    },
    {
      "src": "^/.*",
      "dest": "/index.html"
    }
  ]
}
